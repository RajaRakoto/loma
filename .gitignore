# Rust/Cargo
/target/
Cargo.lock          # library crates: ignore — binary crates: commit (see note)
**/*.rs.bk
*.pdb

# Environment & secrets — NEVER commit these
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx
secrets/

# VS Code
.vscode/
!.vscode/extensions.json   # keep shared extension recommendations if present

# JetBrains (RustRover, CLion, IntelliJ)
.idea/
*.iml

# Vim/Neovim
*.swp
*.swo
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Helix
.helix/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Zed
.zed/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.Trash-*

# Build & CI artefacts
dist/
out/
*.log
*.tmp
*.bak
coverage/
lcov.info
tarpaulin-report.html
tarpaulin-report.json

# Benchmarks
criterion/

# Documentation build output
/doc/
/docs/_site/

# Docker (local overrides only — keep Dockerfile and compose.yml committed)
docker-compose.override.yml
.dockerignore.local

# Miscellaneous
*.orig
*.rej
.cache/

# Own
tmp/